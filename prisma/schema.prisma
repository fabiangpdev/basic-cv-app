generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Resume {
  id           String   @id @default(cuid())
  userId       String?
  personalInfo Json
  experiences  Json
  education    Json
  skills       Json
  certifications Json
  languages    Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("resumes")
}